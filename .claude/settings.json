{
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); output_style=$(echo \"$input\" | jq -r '.output_style.name'); dir_name=$(basename \"$current_dir\"); if [ -d \"$current_dir/.git\" ]; then git_branch=$(cd \"$current_dir\" && git branch --show-current 2>/dev/null || echo 'detached'); git_status=$(cd \"$current_dir\" && git status --porcelain 2>/dev/null | wc -l | tr -d ' '); if [ \"$git_status\" -gt 0 ]; then git_indicator=\" ±$git_status\"; else git_indicator=\"\"; fi; git_info=\" ($git_branch$git_indicator)\"; else git_info=\"\"; fi; printf \"%s in %s%s | %s\" \"$model\" \"$dir_name\" \"$git_info\" \"$output_style\""
  },
  "enabledPlugins": {
    "full-stack-development@claude-code-workflows": false,
    "claude-code-essentials@claude-code-workflows": false,
    "security-hardening@claude-code-workflows": false,
    "incident-response@claude-code-workflows": false,
    "performance-optimization@claude-code-workflows": false,
    "code-quality-review@claude-code-workflows": false,
    "legacy-modernization@claude-code-workflows": false,
    "cicd-automation@claude-code-workflows": false,
    "agent-optimization@claude-code-workflows": false,
    "documentation-generation@claude-code-workflows": false,
    "api-development-kit@claude-code-workflows": false,
    "testing-quality-suite@claude-code-workflows": false,
    "infrastructure-devops@claude-code-workflows": false,
    "development-utilities@claude-code-workflows": false,
    "cloud-infrastructure@claude-code-workflows": false,
    "database-operations@claude-code-workflows": false,
    "seo-content-suite@claude-code-workflows": false,
    "business-analytics@claude-code-workflows": false,
    "blockchain-web3@claude-code-workflows": false,
    "quantitative-trading@claude-code-workflows": false,
    "payment-processing@claude-code-workflows": false,
    "accessibility-compliance@claude-code-workflows": false,
    "javascript-typescript@claude-code-workflows": false,
    "code-documentation@claude-code-workflows": false,
    "full-stack-orchestration@claude-code-workflows": true,
    "agent-orchestration@claude-code-workflows": true,
    "code-refactoring@claude-code-workflows": true,
    "code-review-ai@claude-code-workflows": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  }
}
